{
  "expo": {
    "name": "Fitte",
    "slug": "fitte",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fitte",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fitte.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Fitte needs camera access to photograph your wardrobe items.",
        "NSPhotoLibraryUsageDescription": "Fitte needs photo library access to import your wardrobe.",
        "NSLocationWhenInUseUsageDescription": "Fitte uses your location to get weather and find local stores."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.fitte.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#000000"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e9e516cb-a5e9-4156-ac17-e145fd830bd8"
      }
    },
    "owner": "kosilva93",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e9e516cb-a5e9-4156-ac17-e145fd830bd8"
    }
  }
}
